{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thesispulse.ai/contracts/v1/deployment-manifest.schema.json",
  "title": "ThesisPulse AI Deployment Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "manifest_id",
    "manifest_version",
    "environment",
    "status",
    "created_at_utc",
    "created_by",
    "components",
    "checksum"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0.0"},
    "manifest_id": {"type": "string", "format": "uuid"},
    "manifest_version": {"type": "string", "minLength": 1, "maxLength": 50},
    "environment": {"type": "string", "enum": ["PAPER", "SHADOW", "RESTRICTED_LIVE", "LIVE"]},
    "status": {
      "type": "string",
      "enum": ["DRAFT", "CANDIDATE", "APPROVED", "ACTIVE", "SUSPENDED", "RETIRED", "REJECTED"]
    },
    "created_at_utc": {"type": "string", "format": "date-time"},
    "created_by": {"type": "string", "minLength": 1, "maxLength": 200},
    "effective_from_utc": {"type": ["string", "null"], "format": "date-time"},
    "effective_to_utc": {"type": ["string", "null"], "format": "date-time"},
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_type", "name", "version", "artifact_id", "checksum"],
        "properties": {
          "component_type": {
            "type": "string",
            "enum": [
              "SERVICE",
              "ENGINE",
              "MODEL",
              "FEATURE_SET",
              "STRATEGY_POLICY",
              "FUSION_POLICY",
              "CONFIGURATION",
              "RISK_POLICY",
              "EXECUTION_POLICY",
              "BROKER_CAPABILITY_MATRIX",
              "UNIVERSE",
              "MARKET_CALENDAR",
              "CONTRACT_SCHEMA"
            ]
          },
          "name": {"type": "string", "minLength": 1, "maxLength": 200},
          "version": {"type": "string", "minLength": 1, "maxLength": 100},
          "artifact_id": {"type": "string", "minLength": 1, "maxLength": 200},
          "checksum": {"type": "string", "minLength": 16, "maxLength": 256},
          "source_commit_sha": {"type": ["string", "null"], "maxLength": 64},
          "artifact_uri": {"type": ["string", "null"], "maxLength": 2000}
        }
      }
    },
    "compatibility_result": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "is_compatible": {"type": "boolean"},
        "checked_at_utc": {"type": "string", "format": "date-time"},
        "checker_version": {"type": "string", "minLength": 1, "maxLength": 100},
        "issues": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 1000}
        }
      }
    },
    "approval_records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["approval_type", "decision", "decided_by", "decided_at_utc"],
        "properties": {
          "approval_type": {"type": "string", "enum": ["TECHNICAL", "RISK", "OPERATIONS", "CAPITAL"]},
          "decision": {"type": "string", "enum": ["APPROVED", "REJECTED"]},
          "decided_by": {"type": "string", "minLength": 1, "maxLength": 200},
          "decided_at_utc": {"type": "string", "format": "date-time"},
          "reason": {"type": ["string", "null"], "maxLength": 2000}
        }
      }
    },
    "rollback_manifest_id": {"type": ["string", "null"], "format": "uuid"},
    "checksum": {"type": "string", "minLength": 16, "maxLength": 256},
    "metadata": {"type": "object", "additionalProperties": true}
  }
}
