{
  "Platform": {
    "ConfigurationVersion": "platform-foundation-v1.0.0",
    "Environment": "PAPER",
    "LiveExecutionEnabled": false
  },
  "SignalStream": {
    "IngestionEnabled": false,
    "BufferCapacity": 100
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
