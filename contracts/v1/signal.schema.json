{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thesispulse.ai/contracts/v1/signal.schema.json",
  "title": "ThesisPulse AI Signal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "message_id",
    "correlation_id",
    "causation_id",
    "environment",
    "source_service",
    "source_version",
    "generated_at_utc",
    "signal_id",
    "strategy_id",
    "strategy_version",
    "instrument_id",
    "direction",
    "primary_timeframe",
    "confirmation_timeframes",
    "strength",
    "confidence",
    "entry_window",
    "invalidation",
    "expected_holding_period_minutes",
    "source_engine_output_ids",
    "status",
    "valid_until_utc"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0.0"},
    "message_id": {"type": "string", "format": "uuid"},
    "correlation_id": {"type": "string", "format": "uuid"},
    "causation_id": {"type": ["string", "null"], "format": "uuid"},
    "environment": {"type": "string", "enum": ["PAPER", "SHADOW", "LIVE"]},
    "source_service": {"type": "string", "minLength": 1, "maxLength": 100},
    "source_version": {"type": "string", "minLength": 1, "maxLength": 50},
    "generated_at_utc": {"type": "string", "format": "date-time"},
    "signal_id": {"type": "string", "format": "uuid"},
    "strategy_id": {"type": "string", "minLength": 1, "maxLength": 100},
    "strategy_version": {"type": "string", "minLength": 1, "maxLength": 50},
    "instrument_id": {"type": "string", "minLength": 1, "maxLength": 100},
    "direction": {"type": "string", "enum": ["LONG", "SHORT"]},
    "primary_timeframe": {"type": "string", "enum": ["1m", "5m", "15m", "1h", "1d"]},
    "confirmation_timeframes": {
      "type": "array",
      "items": {"type": "string", "enum": ["1m", "5m", "15m", "1h", "1d"]},
      "uniqueItems": true
    },
    "strength": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "entry_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opens_at_utc", "closes_at_utc", "reference_price"],
      "properties": {
        "opens_at_utc": {"type": "string", "format": "date-time"},
        "closes_at_utc": {"type": "string", "format": "date-time"},
        "reference_price": {"type": "number", "exclusiveMinimum": 0},
        "minimum_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "maximum_price": {"type": ["number", "null"], "exclusiveMinimum": 0}
      }
    },
    "invalidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["price_level", "reason"],
      "properties": {
        "price_level": {"type": "number", "exclusiveMinimum": 0},
        "reason": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    },
    "expected_holding_period_minutes": {"type": "integer", "minimum": 1},
    "source_engine_output_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "format": "uuid"}
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "impact"],
        "properties": {
          "code": {"type": "string", "minLength": 1, "maxLength": 100},
          "message": {"type": "string", "minLength": 1, "maxLength": 1000},
          "impact": {"type": "string", "enum": ["SUPPORTS_LONG", "SUPPORTS_SHORT", "CONTRADICTS", "NEUTRAL"]},
          "weight": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
        }
      }
    },
    "status": {"type": "string", "enum": ["CANDIDATE", "VALIDATED", "REJECTED", "EXPIRED", "SUPERSEDED", "CONSUMED"]},
    "status_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 200},
      "uniqueItems": true
    },
    "valid_until_utc": {"type": "string", "format": "date-time"},
    "supersedes_signal_id": {"type": ["string", "null"], "format": "uuid"},
    "fusion_policy_version": {"type": ["string", "null"], "maxLength": 50},
    "metadata": {"type": "object", "additionalProperties": true}
  }
}
