# ThesisPulse AI local environment template
# Copy this file outside source control when needed and replace placeholders locally.
# Do not commit real values.

THESISPULSE_DATABASE_CONNECTION=<local-sql-connection-string-without-committed-password>

Authentication__Mode=LocalDevelopment
Authentication__Issuer=ThesisPulse.LocalDevelopment
Authentication__Audience=ThesisPulse.Operator
Authentication__Local__Username=operator
Authentication__Local__Password=<generated-by-launcher-or-local-secret-store>
Authentication__Local__SigningKeyBase64=<generated-by-launcher-or-local-secret-store>
Authentication__Local__Permissions__0=thesispulse.read

# External identity provider placeholders for non-local environments only.
Authentication__Authority=<external-identity-provider-authority>
Authentication__ServiceAccessToken=<short-lived-service-token-from-secret-store>

# Broker/vendor placeholders. Never commit real credentials.
Upstox__ClientId=<upstox-client-id-from-secret-store>
Upstox__ClientSecret=<upstox-client-secret-from-secret-store>
Upstox__RedirectUri=<approved-redirect-uri>
Upstox__AccessToken=<runtime-token-from-secret-store>

MarketData__ProviderApiKey=<market-data-provider-key-from-secret-store>
