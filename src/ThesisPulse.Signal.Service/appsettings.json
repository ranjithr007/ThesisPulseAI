{
  "Platform": {
    "ConfigurationVersion": "platform-foundation-v1.0.0",
    "Environment": "PAPER",
    "LiveExecutionEnabled": false
  },
  "Messaging": {
    "Provider": "InMemory",
    "InstanceName": "ThesisPulse.Signal.Service.local",
    "Actor": "ThesisPulse.Signal.Service",
    "MaxAttempts": 5,
    "LeaseSeconds": 60,
    "CommandTimeoutSeconds": 30
  },
  "SignalPersistence": {
    "Provider": "InMemory",
    "CreatorEngineCode": "THESIS_PULSE_THESIS_FUSION",
    "Actor": "ThesisPulse.Signal.Service",
    "CommandTimeoutSeconds": 30
  },
  "ProductionActivation": {
    "Mode": "DISABLED",
    "OperationalSmokeEnabled": false,
    "RequiredSecretNames": [
      "OptionChainRuntime__ConnectionString",
      "OptionChainRuntime__PythonInternalApiKey"
    ]
  },
  "OptionChainCanary": {
    "Mode": "DISABLED",
    "Percentage": 0,
    "InstrumentAllowlist": [],
    "MinimumSampleSize": 20,
    "MinimumSuccessRate": 0.90,
    "MaximumRetryRate": 0.20,
    "MaximumTerminalFailureRate": 0.05,
    "MaximumDuplicateRate": 0.50
  },
  "OptionChainRollback": {
    "AutomaticRollbackEnabled": false,
    "ExplicitRecoveryRequired": true,
    "MaximumReconciliationDrift": 0
  },
  "OptionChainRuntime": {
    "Enabled": false,
    "PersistenceProvider": "SqlServer",
    "ConnectionString": "",
    "MaximumAgeSeconds": 420,
    "MinimumConfidence": 0.0,
    "CommandTimeoutSeconds": 30,
    "WorkerMaximumAttempts": 5,
    "WorkerLeaseSeconds": 120,
    "WorkerInitialRetrySeconds": 10,
    "WorkerMaximumRetrySeconds": 300,
    "WorkerDiscoveryEnabled": false,
    "WorkerPollIntervalSeconds": 30,
    "WorkerBatchSize": 25,
    "WorkerSnapshotMaximumAgeSeconds": 420,
    "WorkerExecutionEnabled": false,
    "WorkerExecutionPollIntervalSeconds": 5,
    "WorkerExecutionBatchSize": 25,
    "PythonServiceBaseUrl": "http://localhost:8000",
    "PythonInternalApiKey": "",
    "PythonRequestTimeoutSeconds": 30,
    "PythonBrokerCode": "UPSTOX"
  },
  "SignalRealtime": {
    "Enabled": false,
    "TradingApiBaseUrl": "http://localhost:5100",
    "TimeoutSeconds": 5
  },
  "SignalMaintenance": {
    "Enabled": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
