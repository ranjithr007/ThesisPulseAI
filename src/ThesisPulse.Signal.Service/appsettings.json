{
  "Platform": {
    "ConfigurationVersion": "platform-foundation-v1.0.0",
    "Environment": "PAPER",
    "LiveExecutionEnabled": false
  },
  "Messaging": {
    "Provider": "InMemory",
    "InstanceName": "ThesisPulse.Signal.Service.local",
    "Actor": "ThesisPulse.Signal.Service",
    "MaxAttempts": 5,
    "LeaseSeconds": 60,
    "CommandTimeoutSeconds": 30
  },
  "SignalPersistence": {
    "Provider": "InMemory",
    "CreatorEngineCode": "THESIS_PULSE_THESIS_FUSION",
    "Actor": "ThesisPulse.Signal.Service",
    "CommandTimeoutSeconds": 30
  },
  "SignalRealtime": {
    "Enabled": false,
    "TradingApiBaseUrl": "http://localhost:5100",
    "TimeoutSeconds": 5
  },
  "SignalMaintenance": {
    "Enabled": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
