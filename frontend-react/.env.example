# Same-origin paths proxied by Vite to canonical local ASP.NET Core ports.
VITE_TRADING_API_BASE_URL=/local/trading
VITE_SIGNAL_API_BASE_URL=/local/signal
VITE_THESIS_API_BASE_URL=/local/thesis
VITE_RISK_API_BASE_URL=/local/risk
VITE_EXECUTION_API_BASE_URL=/local/execution
VITE_PORTFOLIO_API_BASE_URL=/local/portfolio
VITE_OPERATIONS_API_BASE_URL=/local/operations

# PAPER workspace defaults.
VITE_PORTFOLIO_CODE=PAPER-DEFAULT
VITE_PORTFOLIO_CURRENCY=INR
VITE_EXECUTION_LIFECYCLE_LIMIT=50
VITE_PNL_MAXIMUM_AGE_MINUTES=10
