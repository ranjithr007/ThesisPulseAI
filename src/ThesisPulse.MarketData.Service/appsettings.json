{
  "Platform": {
    "ConfigurationVersion": "platform-foundation-v1.0.0",
    "Environment": "PAPER",
    "LiveExecutionEnabled": false
  },
  "Upstox": {
    "Enabled": false,
    "ApiBaseUrl": "https://api.upstox.com",
    "InstrumentMasterUrl": "https://assets.upstox.com/market-quote/instruments/exchange/NSE.json.gz",
    "HistoricalPathTemplate": "/v3/historical-candle/{instrumentKey}/{unit}/{interval}/{toDate}/{fromDate}",
    "MarketFeedAuthorizePath": "/v3/feed/market-data-feed/authorize",
    "TickSizeDivisor": 100,
    "RequestTimeoutSeconds": 30,
    "MaximumInstrumentCount": 500000,
    "LiveFeed": {
      "Enabled": false,
      "Mode": "full",
      "InstrumentKeys": [],
      "ConnectTimeoutSeconds": 20,
      "MessageSilenceTimeoutSeconds": 45,
      "ClosedMarketMessageSilenceTimeoutSeconds": 300,
      "KeepAliveSeconds": 20,
      "InitialReconnectDelayMilliseconds": 1000,
      "MaximumReconnectDelayMilliseconds": 60000,
      "StableConnectionResetSeconds": 60,
      "ReceiveBufferBytes": 65536,
      "MaximumMessageBytes": 4194304
    }
  },
  "MarketData": {
    "Operations": {
      "Enabled": false,
      "MaximumHistoricalDays": 366
    },
    "Persistence": {
      "Provider": "InMemory",
      "BrokerCode": "UPSTOX",
      "HistoricalSourceCode": "UPSTOX_REST",
      "LiveSourceCode": "UPSTOX_WS",
      "Actor": "ThesisPulse.MarketData.Service",
      "CommandTimeoutSeconds": 30
    },
    "Freshness": {
      "PolicyVersion": "market-freshness-v1.0.0",
      "LiveQuoteMaximumAgeMs": 5000,
      "OneMinuteMaximumAgeMs": 90000,
      "FiveMinuteMaximumAgeMs": 420000,
      "FifteenMinuteMaximumAgeMs": 1200000,
      "OneHourMaximumAgeMs": 4500000,
      "OneDayMaximumAgeMs": 129600000,
      "ExitAgeMultiplier": 5
    },
    "Recovery": {
      "Enabled": false,
      "Timeframe": "5m",
      "PollIntervalSeconds": 60,
      "GracePeriodSeconds": 45,
      "MaximumGapCandles": 500,
      "MaximumRecoveryDays": 30,
      "SessionOpenIndia": "09:15",
      "SessionCloseIndia": "15:30"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
