{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thesispulse.ai/contracts/v1/thesis.schema.json",
  "title": "ThesisPulse AI Trade Thesis v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "message_id",
    "correlation_id",
    "causation_id",
    "environment",
    "source_service",
    "source_version",
    "generated_at_utc",
    "thesis_id",
    "signal_id",
    "thesis_version",
    "instrument_id",
    "market_regime",
    "primary_hypothesis",
    "supporting_evidence",
    "contradicting_evidence",
    "assumptions",
    "invalidation_conditions",
    "scenarios",
    "confidence",
    "status",
    "valid_until_utc"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0.0"},
    "message_id": {"type": "string", "format": "uuid"},
    "correlation_id": {"type": "string", "format": "uuid"},
    "causation_id": {"type": ["string", "null"], "format": "uuid"},
    "environment": {"type": "string", "enum": ["PAPER", "SHADOW", "LIVE"]},
    "source_service": {"type": "string", "minLength": 1, "maxLength": 100},
    "source_version": {"type": "string", "minLength": 1, "maxLength": 50},
    "generated_at_utc": {"type": "string", "format": "date-time"},
    "thesis_id": {"type": "string", "format": "uuid"},
    "signal_id": {"type": "string", "format": "uuid"},
    "thesis_version": {"type": "integer", "minimum": 1},
    "instrument_id": {"type": "string", "minLength": 1, "maxLength": 100},
    "market_regime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "confidence", "as_of_utc", "engine_output_id"],
      "properties": {
        "code": {"type": "string", "minLength": 1, "maxLength": 100},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "as_of_utc": {"type": "string", "format": "date-time"},
        "engine_output_id": {"type": "string", "format": "uuid"}
      }
    },
    "primary_hypothesis": {"type": "string", "minLength": 1, "maxLength": 4000},
    "supporting_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/evidence"}
    },
    "contradicting_evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence"}
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 1000}
    },
    "invalidation_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "description", "severity"],
        "properties": {
          "code": {"type": "string", "minLength": 1, "maxLength": 100},
          "description": {"type": "string", "minLength": 1, "maxLength": 1000},
          "severity": {"type": "string", "enum": ["WARNING", "INVALIDATES"]},
          "price_level": {"type": ["number", "null"], "exclusiveMinimum": 0}
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "probability", "is_primary"],
        "properties": {
          "name": {"type": "string", "minLength": 1, "maxLength": 100},
          "description": {"type": "string", "minLength": 1, "maxLength": 2000},
          "probability": {"type": "number", "minimum": 0, "maximum": 1},
          "is_primary": {"type": "boolean"}
        }
      }
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "status": {"type": "string", "enum": ["DRAFT", "VALIDATED", "REJECTED", "EXPIRED", "SUPERSEDED"]},
    "status_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 200},
      "uniqueItems": true
    },
    "valid_until_utc": {"type": "string", "format": "date-time"},
    "supersedes_thesis_id": {"type": ["string", "null"], "format": "uuid"},
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "description", "source_type", "source_id", "impact"],
      "properties": {
        "code": {"type": "string", "minLength": 1, "maxLength": 100},
        "description": {"type": "string", "minLength": 1, "maxLength": 1000},
        "source_type": {"type": "string", "enum": ["ENGINE_OUTPUT", "MARKET_SNAPSHOT", "SIGNAL", "POLICY", "OTHER"]},
        "source_id": {"type": "string", "minLength": 1, "maxLength": 100},
        "impact": {"type": "string", "enum": ["SUPPORTS", "CONTRADICTS", "NEUTRAL"]},
        "weight": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
      }
    }
  }
}
