{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thesispulse.ai/contracts/v1/learning-candidate.schema.json",
  "title": "ThesisPulse AI Learning Candidate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "candidate_id",
    "candidate_version",
    "candidate_type",
    "status",
    "created_at_utc",
    "created_by",
    "source_outcome_ids",
    "hypothesis",
    "proposed_change",
    "affected_components",
    "evaluation_plan",
    "acceptance_criteria",
    "rejection_criteria"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0.0"},
    "candidate_id": {"type": "string", "format": "uuid"},
    "candidate_version": {"type": "integer", "minimum": 1},
    "candidate_type": {
      "type": "string",
      "enum": [
        "WEIGHT_CHANGE",
        "THRESHOLD_CHANGE",
        "FEATURE_CHANGE",
        "REGIME_POLICY_CHANGE",
        "SIGNAL_RULE_CHANGE",
        "ENTRY_RULE_CHANGE",
        "STOP_TARGET_CHANGE",
        "RISK_RESTRICTION",
        "UNIVERSE_RESTRICTION",
        "EXECUTION_TOLERANCE_CHANGE",
        "MODEL_RETRAIN",
        "DATA_QUALITY_CONTROL",
        "OPERATIONAL_REMEDIATION"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "CANDIDATE",
        "OFFLINE_VALIDATION",
        "WALK_FORWARD_VALIDATION",
        "PAPER_VALIDATION",
        "SHADOW_VALIDATION",
        "RESTRICTED_LIVE_VALIDATION",
        "APPROVED",
        "REJECTED",
        "SUSPENDED",
        "RETIRED"
      ]
    },
    "created_at_utc": {"type": "string", "format": "date-time"},
    "created_by": {"type": "string", "minLength": 1, "maxLength": 200},
    "source_outcome_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "format": "uuid"}
    },
    "source_incident_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "format": "uuid"}
    },
    "hypothesis": {"type": "string", "minLength": 1, "maxLength": 4000},
    "proposed_change": {"type": "string", "minLength": 1, "maxLength": 4000},
    "expected_benefit": {"type": ["string", "null"], "maxLength": 4000},
    "known_risks": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 2000}
    },
    "affected_components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_type", "name", "current_version"],
        "properties": {
          "component_type": {"type": "string", "minLength": 1, "maxLength": 100},
          "name": {"type": "string", "minLength": 1, "maxLength": 200},
          "current_version": {"type": "string", "minLength": 1, "maxLength": 100},
          "proposed_version": {"type": ["string", "null"], "maxLength": 100}
        }
      }
    },
    "root_causes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "confidence"],
        "properties": {
          "code": {"type": "string", "minLength": 1, "maxLength": 100},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence": {"type": ["string", "null"], "maxLength": 4000}
        }
      }
    },
    "evaluation_plan": {"type": "string", "minLength": 1, "maxLength": 8000},
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "maxLength": 2000}
    },
    "rejection_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "maxLength": 2000}
    },
    "minimum_sample_size": {"type": ["integer", "null"], "minimum": 1},
    "minimum_observation_days": {"type": ["integer", "null"], "minimum": 1},
    "champion_manifest_id": {"type": ["string", "null"], "format": "uuid"},
    "challenger_manifest_id": {"type": ["string", "null"], "format": "uuid"},
    "validation_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "result", "evaluated_at_utc", "evaluator_version"],
        "properties": {
          "stage": {"type": "string", "enum": ["OFFLINE", "WALK_FORWARD", "PAPER", "SHADOW", "RESTRICTED_LIVE"]},
          "result": {"type": "string", "enum": ["PASSED", "FAILED", "INCONCLUSIVE"]},
          "evaluated_at_utc": {"type": "string", "format": "date-time"},
          "evaluator_version": {"type": "string", "minLength": 1, "maxLength": 100},
          "evidence_uri": {"type": ["string", "null"], "maxLength": 2000},
          "notes": {"type": ["string", "null"], "maxLength": 4000}
        }
      }
    },
    "approval_records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["approval_type", "decision", "decided_by", "decided_at_utc"],
        "properties": {
          "approval_type": {"type": "string", "enum": ["TECHNICAL", "RISK", "OPERATIONS", "CAPITAL"]},
          "decision": {"type": "string", "enum": ["APPROVED", "REJECTED"]},
          "decided_by": {"type": "string", "minLength": 1, "maxLength": 200},
          "decided_at_utc": {"type": "string", "format": "date-time"},
          "reason": {"type": ["string", "null"], "maxLength": 4000}
        }
      }
    },
    "rollback_triggers": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 2000}
    },
    "metadata": {"type": "object", "additionalProperties": true}
  }
}
