{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thesispulse.ai/contracts/v1/order-event.schema.json",
  "title": "ThesisPulse AI Order Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "message_id",
    "correlation_id",
    "causation_id",
    "environment",
    "source_service",
    "source_version",
    "generated_at_utc",
    "order_event_id",
    "order_id",
    "execution_command_id",
    "trade_plan_id",
    "broker_account_id",
    "instrument_id",
    "side",
    "event_type",
    "previous_status",
    "normalized_status",
    "event_at_utc",
    "received_at_utc",
    "order_version"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0.0"},
    "message_id": {"type": "string", "format": "uuid"},
    "correlation_id": {"type": "string", "format": "uuid"},
    "causation_id": {"type": ["string", "null"], "format": "uuid"},
    "environment": {"type": "string", "enum": ["PAPER", "SHADOW", "LIVE"]},
    "source_service": {"type": "string", "minLength": 1, "maxLength": 100},
    "source_version": {"type": "string", "minLength": 1, "maxLength": 50},
    "generated_at_utc": {"type": "string", "format": "date-time"},
    "order_event_id": {"type": "string", "format": "uuid"},
    "order_id": {"type": "string", "format": "uuid"},
    "execution_command_id": {"type": "string", "format": "uuid"},
    "trade_plan_id": {"type": "string", "format": "uuid"},
    "broker_account_id": {"type": "string", "minLength": 1, "maxLength": 100},
    "broker_order_id": {"type": ["string", "null"], "maxLength": 200},
    "instrument_id": {"type": "string", "minLength": 1, "maxLength": 100},
    "side": {"type": "string", "enum": ["BUY", "SELL"]},
    "event_type": {
      "type": "string",
      "enum": [
        "CREATED",
        "VALIDATED",
        "SUBMISSION_PENDING",
        "SUBMITTED",
        "ACKNOWLEDGED",
        "PARTIALLY_FILLED",
        "FILLED",
        "MODIFY_PENDING",
        "MODIFIED",
        "CANCEL_PENDING",
        "CANCELLED",
        "REJECTED",
        "FAILED",
        "EXPIRED",
        "RECONCILIATION_REQUIRED",
        "RECONCILED"
      ]
    },
    "previous_status": {
      "type": ["string", "null"],
      "enum": [
        "CREATED",
        "VALIDATED",
        "SUBMISSION_PENDING",
        "SUBMITTED",
        "ACKNOWLEDGED",
        "PARTIALLY_FILLED",
        "FILLED",
        "MODIFY_PENDING",
        "MODIFIED",
        "CANCEL_PENDING",
        "CANCELLED",
        "REJECTED",
        "FAILED",
        "EXPIRED",
        "RECONCILIATION_REQUIRED",
        null
      ]
    },
    "normalized_status": {
      "type": "string",
      "enum": [
        "CREATED",
        "VALIDATED",
        "SUBMISSION_PENDING",
        "SUBMITTED",
        "ACKNOWLEDGED",
        "PARTIALLY_FILLED",
        "FILLED",
        "MODIFY_PENDING",
        "MODIFIED",
        "CANCEL_PENDING",
        "CANCELLED",
        "REJECTED",
        "FAILED",
        "EXPIRED",
        "RECONCILIATION_REQUIRED"
      ]
    },
    "broker_status": {"type": ["string", "null"], "maxLength": 100},
    "reason_code": {"type": ["string", "null"], "maxLength": 100},
    "reason_message": {"type": ["string", "null"], "maxLength": 2000},
    "requested_qty": {"type": ["number", "null"], "minimum": 0},
    "filled_qty": {"type": ["number", "null"], "minimum": 0},
    "remaining_qty": {"type": ["number", "null"], "minimum": 0},
    "average_fill_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "limit_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "trigger_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "event_at_utc": {"type": "string", "format": "date-time"},
    "received_at_utc": {"type": "string", "format": "date-time"},
    "order_version": {"type": "integer", "minimum": 0},
    "broker_sequence": {"type": ["string", "integer", "null"]},
    "is_reconciliation_event": {"type": "boolean", "default": false},
    "metadata": {"type": "object", "additionalProperties": true}
  }
}
