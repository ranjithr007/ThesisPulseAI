{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thesispulse.ai/contracts/v1/execution-command.schema.json",
  "title": "ThesisPulse AI Execution Command v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "message_id",
    "correlation_id",
    "causation_id",
    "environment",
    "source_service",
    "source_version",
    "generated_at_utc",
    "execution_command_id",
    "trade_plan_id",
    "broker_account_id",
    "command_type",
    "idempotency_key",
    "execution_policy_version",
    "valid_until_utc"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "1.0.0"},
    "message_id": {"type": "string", "format": "uuid"},
    "correlation_id": {"type": "string", "format": "uuid"},
    "causation_id": {"type": ["string", "null"], "format": "uuid"},
    "environment": {"type": "string", "enum": ["PAPER", "SHADOW", "LIVE"]},
    "source_service": {"type": "string", "minLength": 1, "maxLength": 100},
    "source_version": {"type": "string", "minLength": 1, "maxLength": 50},
    "generated_at_utc": {"type": "string", "format": "date-time"},
    "execution_command_id": {"type": "string", "format": "uuid"},
    "trade_plan_id": {"type": "string", "format": "uuid"},
    "broker_account_id": {"type": "string", "minLength": 1, "maxLength": 100},
    "command_type": {"type": "string", "enum": ["PLACE", "MODIFY", "CANCEL"]},
    "idempotency_key": {"type": "string", "minLength": 8, "maxLength": 200},
    "execution_policy_version": {"type": "string", "minLength": 1, "maxLength": 50},
    "instrument_id": {"type": ["string", "null"], "minLength": 1, "maxLength": 100},
    "side": {"type": ["string", "null"], "enum": ["BUY", "SELL", null]},
    "position_intent": {"type": ["string", "null"], "enum": ["INTRADAY", "DELIVERY", "CARRY_FORWARD", null]},
    "quantity": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "order_type": {"type": ["string", "null"], "enum": ["MARKET", "LIMIT", "STOP_MARKET", "STOP_LIMIT", null]},
    "limit_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "trigger_price": {"type": ["number", "null"], "exclusiveMinimum": 0},
    "time_in_force": {"type": ["string", "null"], "enum": ["DAY", "IOC", null]},
    "client_order_id": {"type": ["string", "null"], "maxLength": 100},
    "target_order_id": {"type": ["string", "null"], "format": "uuid"},
    "expected_order_version": {"type": ["integer", "null"], "minimum": 0},
    "change_reason_code": {"type": ["string", "null"], "maxLength": 100},
    "requested_at_utc": {"type": ["string", "null"], "format": "date-time"},
    "valid_until_utc": {"type": "string", "format": "date-time"},
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "allOf": [
    {
      "if": {"properties": {"command_type": {"const": "PLACE"}}},
      "then": {
        "required": ["instrument_id", "side", "position_intent", "quantity", "order_type", "time_in_force", "client_order_id"]
      }
    },
    {
      "if": {"properties": {"command_type": {"const": "MODIFY"}}},
      "then": {
        "required": ["target_order_id", "expected_order_version", "change_reason_code"],
        "anyOf": [
          {"required": ["quantity"]},
          {"required": ["order_type"]},
          {"required": ["limit_price"]},
          {"required": ["trigger_price"]}
        ]
      }
    },
    {
      "if": {"properties": {"command_type": {"const": "CANCEL"}}},
      "then": {
        "required": ["target_order_id", "expected_order_version", "change_reason_code"]
      }
    },
    {
      "if": {"properties": {"order_type": {"const": "LIMIT"}}},
      "then": {"required": ["limit_price"]}
    },
    {
      "if": {"properties": {"order_type": {"enum": ["STOP_MARKET", "STOP_LIMIT"]}}},
      "then": {"required": ["trigger_price"]}
    },
    {
      "if": {"properties": {"order_type": {"const": "STOP_LIMIT"}}},
      "then": {"required": ["limit_price", "trigger_price"]}
    }
  ]
}
